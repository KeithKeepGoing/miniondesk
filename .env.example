# ============================================================
# MinionDesk Configuration
# Copy to .env and fill in your values.
# ============================================================

# ── LLM Provider (choose ONE or set LLM_PROVIDER to force) ──
# Priority order: Claude > Gemini > OpenAI > Ollama
#
# Force a specific provider: claude | gemini | openai | ollama | vllm
# LLM_PROVIDER=claude

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=your_anthropic_key_here
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# Google Gemini (free tier available)
# GOOGLE_API_KEY=your_google_key_here
# GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local, fully offline)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Embedding (for semantic KB search — optional) ────────────
# Uses OPENAI_API_KEY / OPENAI_BASE_URL if set, otherwise Ollama
# EMBEDDING_MODEL=text-embedding-3-small
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Messaging Channels ───────────────────────────────────────
# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token

# Discord
# DISCORD_TOKEN=your_discord_bot_token

# Microsoft Teams (Bot Framework)
# TEAMS_APP_ID=your_teams_app_id
# TEAMS_APP_PASSWORD=your_teams_app_password
# TEAMS_WEBHOOK_PORT=8443

# ── Minions ──────────────────────────────────────────────────
# Default minion when no routing match found
# DEFAULT_MINION=phil

# ── Routing ──────────────────────────────────────────────────
# ROUTING_MODEL=claude-3-haiku-20240307   # LLM for dept routing

# ── Storage Paths ────────────────────────────────────────────
# DATA_DIR=./data          # SQLite DB, KB, logs
# IPC_DIR=./ipc            # Container ↔ host communication

# ── Docker ───────────────────────────────────────────────────
# DOCKER_IMAGE=miniondesk-runner:latest
# DOCKER_MEMORY=512m       # Memory limit per container
# DOCKER_CPUS=1.0          # CPU limit per container
# DOCKER_NETWORK=none      # Network mode (none = no internet)
# CONTAINER_TIMEOUT=120    # Max seconds to wait for response

# ── Workflow Settings ────────────────────────────────────────
# WORKFLOW_EXPIRY_DAYS=7   # Auto-expire pending workflows after N days
# WORKFLOW_REMINDER_DAYS=2 # Send manager reminder after N days pending

# ── Logging ──────────────────────────────────────────────────
# LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
# Log file: $DATA_DIR/miniondesk.log (auto-rotating, 10MB × 5 files)

# ── Health Check ─────────────────────────────────────────────
# HEALTH_PORT=8080         # Port for /health and /metrics endpoints

# ── Security ─────────────────────────────────────────────────
# Rate limiting (per user per minute)
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW=60

# ── Web Portal ───────────────────────────────────────────────
# Set to true to enable the browser-based chat interface on port 8082
WEBPORTAL_ENABLED=false
WEBPORTAL_PORT=8082
WEBPORTAL_HOST=0.0.0.0

# ── Admin Dashboard ──────────────────────────────────────────
DASHBOARD_ENABLED=false
DASHBOARD_PORT=8084
DASHBOARD_PASSWORD=your_admin_password

# ── Confluence Knowledge Base Sync ───────────────────────────
CONFLUENCE_URL=https://corp.atlassian.net/wiki
CONFLUENCE_USER=it-bot@corp.com
CONFLUENCE_TOKEN=your_confluence_api_token
CONFLUENCE_SPACES=IT,HR,INFRA

# ── SharePoint Knowledge Base Sync ───────────────────────────
SHAREPOINT_URL=https://corp.sharepoint.com/sites/IT
SHAREPOINT_TOKEN=your_azure_ad_access_token

# Weekly Report (auto-send every Friday 17:00)
WEEKLY_REPORT_ENABLED=false
WEEKLY_REPORT_DAY=4          # 0=Monday, 4=Friday
WEEKLY_REPORT_HOUR=17        # 24-hour format
WEEKLY_REPORT_JIRA_PROJECT=IT
WEEKLY_REPORT_GITLAB_PROJECT=namespace/project

# ── HPC / IC Design Infrastructure ───────────────────────────
# LSF job scheduler (IBM Platform LSF / IBM Spectrum LSF)
# HPC_LSF_HOST=lsf-head.corp.local        # SSH host for bjobs/bqueues commands

# Slurm job scheduler
# HPC_SLURM_HOST=slurm-head.corp.local    # SSH host for squeue/sinfo commands

# FlexLM license server (EDA tools: VCS, DC Shell, ICC2, Calibre, etc.)
# FLEXLM_SERVER=license.corp.local:27000  # host:port of FlexLM server

# NAS storage management host
# NAS_HOST=nas.corp.local                 # SSH host for df/quota queries

# SSH key for HPC/NAS authentication (optional, uses default key if not set)
# HPC_SSH_KEY_PATH=/home/user/.ssh/hpc_rsa

# ── Enterprise Integrations ───────────────────────────────────
# Jira (Atlassian Cloud or Server)
# JIRA_URL=https://corp.atlassian.net       # Jira base URL
# JIRA_USER=user@corp.com                   # Jira account email
# JIRA_TOKEN=your_jira_api_token            # API token from id.atlassian.com/manage-profile/security
# JIRA_DEFAULT_PROJECT=IT                   # Default project key for new tickets

# ServiceNow
# SERVICENOW_URL=https://corp.service-now.com  # ServiceNow instance URL
# SERVICENOW_USER=admin                        # ServiceNow username
# SERVICENOW_PASSWORD=your_snow_password       # ServiceNow password

# GitLab
# GITLAB_URL=https://gitlab.com             # GitLab instance URL (default: gitlab.com)
# GITLAB_TOKEN=your_gitlab_personal_token   # Personal access token with read_api scope

# GitHub — Required for agent to use git push / gh repo create / gh pr create inside containers.
# Generate at: https://github.com/settings/tokens (needs repo scope)
# GITHUB_TOKEN=ghp_your_github_token_here

# Email (IMAP/SMTP)
EMAIL_IMAP_HOST=outlook.office365.com
EMAIL_USER=it-bot@corp.com
EMAIL_PASSWORD=your_app_password
EMAIL_SMTP_HOST=smtp.office365.com

# IBM Lotus Notes / HCL Domino Mail
# Method 1: Domino REST API (recommended)
DOMINO_REST_URL=https://domino.corp.local:8880
DOMINO_REST_USER=firstname.lastname
DOMINO_REST_PASSWORD=your_notes_password
DOMINO_DATABASE=mail/username.nsf

# Method 2: Domino IMAP (enable IMAP on Domino server first)
NOTES_IMAP_HOST=domino.corp.local
NOTES_IMAP_PORT=993
NOTES_USER=your_notes_username
NOTES_PASSWORD=your_notes_password

# Method 3: noteslib (Windows only, requires HCL Notes client)
# pip install noteslib
NOTES_SERVER=DominoServer/Corp
NOTES_MAILDB=mail\username.nsf

# Jira Webhook (receive Jira events)
JIRA_WEBHOOK_ENABLED=false
JIRA_WEBHOOK_PORT=8083
JIRA_WEBHOOK_SECRET=your_webhook_secret

# NAS Deep API (NetApp ONTAP / IBM Spectrum Scale)
NETAPP_URL=https://netapp.corp.local
NETAPP_USER=admin
NETAPP_PASSWORD=your_netapp_password
NETAPP_SVM=svm_name

GPFS_URL=https://gpfs.corp.local:443
GPFS_USER=admin
GPFS_PASSWORD=your_gpfs_password
GPFS_FILESYSTEM=fs1
