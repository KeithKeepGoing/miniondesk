# === LLM Provider（至少設定一個）===
# MinionDesk 會自動選擇第一個可用的 API key
GOOGLE_API_KEY=               # Gemini（優先，有免費額度）
ANTHROPIC_API_KEY=            # Claude（高品質推理）
OPENAI_API_KEY=               # OpenAI
OLLAMA_URL=http://localhost:11434  # 本地模型（完全離線）
OPENAI_BASE_URL=              # vLLM / LM Studio（自架 OpenAI-compatible）

# === Telegram Bot（至少設定一個 Channel）===
TELEGRAM_TOKEN=

# === Discord Bot（可選）===
DISCORD_TOKEN=

# === 資料目錄 ===
DATA_DIR=./data
GROUPS_DIR=./groups
KNOWLEDGE_DIR=./knowledge

# === 安全 ===
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_PASSWORD=changeme

# === 助理名稱 ===
ASSISTANT_NAME=Mini

# === Docker ===
CONTAINER_IMAGE=miniondesk-agent:latest
CONTAINER_TIMEOUT=300
